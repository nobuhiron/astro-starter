# .env.development と .env.production の両方で同じキーを使う。
# このファイルをコピーして、値を案件のものに差し替える。
#
#   cp .env.example .env.development
#   cp .env.example .env.production
#
# どちらも .gitignore 済み。コミットしないこと。

# MakeShop の商品 URL ベース（末尾スラッシュあり）
PUBLIC_LINK_BASE=https://<shop-domain>/view/item/

# ビルド成果物を置く CDN パス（astro.config.mjs の assetsPrefix に渡る）
# 末尾スラッシュは付けない
CDN_URL=https://gigaplus.makeshop.jp/<shop-id>/feature-page/<page-slug>
